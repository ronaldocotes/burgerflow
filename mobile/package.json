{
  "name": "burgerflow-mobile",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "test": "jest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "type-check": "tsc --noEmit",
    "pod-install": "cd ios && pod install && cd ..",
    "clean": "rm -rf node_modules && npm install",
    "reset-cache": "rm -rf ~/.metro/cache && npm start -- --reset-cache",
    "log-android": "adb logcat *:S ReactNative:V ReactNativeJS:V",
    "log-ios": "npx react-native log-ios",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "cd ios && xcodebuild -workspace BurgerFlow.xcworkspace -scheme BurgerFlow -configuration Release",
    "eject": "react-native eject"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.23.1",
    "@react-native-community/masked-view": "^0.1.11",
    "@react-native-community/netinfo": "^11.2.1",
    "@react-native-google-signin/google-signin": "^12.0.0",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/native-stack": "^6.9.17",
    "@react-navigation/stack": "^6.3.17",
    "@shopify/restyle": "^2.7.2",
    "axios": "^1.7.2",
    "date-fns": "^3.6.0",
    "i18next": "^23.11.3",
    "react": "18.3.1",
    "react-i18next": "^14.1.1",
    "react-native": "0.74.1",
    "react-native-biometrics": "^4.0.5",
    "react-native-config": "^1.5.1",
    "react-native-device-info": "^10.12.0",
    "react-native-gesture-handler": "^2.14.1",
    "react-native-image-picker": "^7.1.0",
    "react-native-keychain": "^8.1.2",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-mmkv": "^2.12.2",
    "react-native-modal": "^13.0.1",
    "react-native-pager-view": "^6.3.0",
    "react-native-permissions": "^3.9.0",
    "react-native-qrcode-scanner": "^1.6.7",
    "react-native-reanimated": "^3.6.2",
    "react-native-safe-area-context": "^4.8.2",
    "react-native-screens": "^3.29.0",
    "react-native-svg": "^15.2.0",
    "react-native-toast-message": "^2.2.1",
    "react-native-vector-icons": "^10.0.3",
    "react-query": "^3.39.3",
    "socket.io-client": "^4.7.5",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@react-native-community/eslint-config": "^3.2.0",
    "@react-native-typescript/type-check": "^0.1.2",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.4.3",
    "@tsconfig/react-native": "^3.0.1",
    "@types/i18next": "^13.0.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.3.3",
    "@types/react-test-renderer": "^18.0.7",
    "@types/socket.io-client": "^1.4.3",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "eslint-plugin-jest": "^27.9.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jest": "^29.7.0",
    "metro-react-native-babel-preset": "0.74.1",
    "prettier": "^3.2.5",
    "react-native-svg-transformer": "^1.3.0",
    "react-test-renderer": "18.3.1",
    "typescript": "^5.4.5"
  },
  "resolutions": {
    "react": "18.3.1",
    "react-native": "0.74.1"
  },
  "jest": {
    "preset": "react-native",
    "setupFilesAfterEnv": [
      "@testing-library/jest-native/extend-expect"
    ],
    "setupFiles": [
      "./jest/setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.[jt]s?(x)",
      "**/?(*.)+(spec|test).[t]s?(x)"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!(@react-native|react-native|react-native-.*|@react-navigation/.*|@shopify/restyle)/)"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  }
}
