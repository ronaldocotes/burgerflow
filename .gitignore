# =============================================================================
# MenuFlow - .gitignore
# =============================================================================

# =============================================================================
# General
# =============================================================================

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# Logs
*.log
*.log.*
.codex-run/
nohup.out
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment
.env
.env.local
.env.development
.env.test
.env.production
.env.*
!.env.example

# Cache
.cache/
*.cache
npm/
.pnpm/
yarn/

# =============================================================================
# Backend (Spring Boot)
# =============================================================================
backend/build/
backend/.gradle/
backend/out/
backend/**/*.iml
backend/.idea/

# =============================================================================
# Frontend (Next.js)
# =============================================================================
frontend/.next/
frontend/out/
frontend/node_modules/
frontend/dist/
frontend/build/
frontend/*.tsbuildinfo

# =============================================================================
# Mobile (React Native)
# =============================================================================
mobile/node_modules/
mobile/.metro/
mobile/android/.gradle/
mobile/android/build/
mobile/android/local.properties
mobile/ios/Pods/
mobile/ios/build/
mobile/ios/DerivedData/

# =============================================================================
# IA (FastAPI)
# =============================================================================
ia/__pycache__/
ia/**/__pycache__/
ia/*.pyc
ia/venv/
ia/.venv/
ia/**/*.egg-info/
ia/.pytest_cache/
ia/.mypy_cache/

# =============================================================================
# Docker / K8s
# =============================================================================
docker/postgres-data/
docker/redis-data/

# =============================================================================
# Tests coverage
# =============================================================================
testes/coverage/
testes/.nyc_output/

# =============================================================================
# Misc
# =============================================================================

# Temp files
*.tmp
*.temp
*~

# Backup files
*.bak
*.backup
*.old

# Thumbnail cache
.DS_Store
Thumbs.db

# macOS
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# Linux
*~
.nfs*

# Windows
Thumbs.db
ehthumbs.db
$RECYCLE.BIN/

# =============================================================================
