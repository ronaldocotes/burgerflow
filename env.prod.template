# MenuFlow production env TEMPLATE for the canonical root compose.
# Copy to `.env.prod` ON THE A1 HOST and fill real values with openssl.
# NEVER commit `.env.prod`; `.env.*` is gitignored.
#
# Generate strong secrets on the host:
#   MF_JWT_SECRET:          openssl rand -base64 48
#   MF_DB_PASSWORD:         openssl rand -base64 24
#   SPRING_REDIS_PASSWORD:  openssl rand -base64 24
#   IFOOD_ENCRYPTION_KEY:   openssl rand -base64 32

# Postgres control DB + database-per-tenant.
MF_DB_USER=menuflow
MF_DB_PASSWORD=CHANGE-ME
MF_DB_CONTROL=menuflow_control
MF_DB_MAINTENANCE=menuflow_control
MF_DB_PREFIX=tenant_
MF_DB_AUTOCREATE=true

# Redis shared rate-limit/cache.
SPRING_REDIS_PASSWORD=CHANGE-ME

# JWT signing secret. No prod fallback: missing/empty secret must fail startup.
MF_JWT_SECRET=CHANGE-ME

# Cifra AES-256-GCM (32 bytes base64) para tokens iFood (IfoodTokenCipher) e
# segredo TOTP do 2FA do super-admin (TotpService reusa o mesmo cifrador, ver
# migration V15). SEM prod fallback fail-fast: com a env ausente, a app SOBE
# normalmente usando o placeholder do application.yml — não quebra no boot,
# mas qualquer cifra feita com o placeholder fica ILEGÍVEL assim que a env
# for definida depois (e vice-versa). Definir ANTES do primeiro deploy que
# usar iFood ou 2FA, e NUNCA rotacionar sem antes desativar/re-cifrar os
# segredos já persistidos (senão 2FA já configurado vira inacessível).
IFOOD_ENCRYPTION_KEY=CHANGE-ME

# Tenant demo do cardapio publico. O frontend eh buildado sem tenant fixo
# (o storefront resolve o tenant pela URL, /l/{tenant}/{slug}); o codigo
# cai no fallback "demo" quando nao ha query/slug (rota legada /cardapio).
# O deploy (scripts/seed-demo-prod.sh) garante tenant + admin + produtos de
# forma idempotente. Sem MF_DEMO_ADMIN_PASSWORD o seed e PULADO e, num banco
# novo, o /cardapio fica fora do ar (404 em /public/demo/menu).
#   MF_DEMO_ADMIN_PASSWORD: openssl rand -base64 18
MF_DEMO_ADMIN_EMAIL=admin@demo.com
MF_DEMO_ADMIN_PASSWORD=CHANGE-ME

# Google Routes/Geocoding API key (DistanceService + GeocodingService). OPCIONAL:
# vazio = geocode sempre null / distância cai em Haversine (fail-safe, nunca quebra
# o boot). Mas tenant com zonas de entrega ativas (issue #2) fica fail-closed (422)
# no delivery público sem isto, porque o frete SERVER-SIDE exige coordenadas do
# destino. 10k geocodes/mês grátis. Precisa também estar listada no environment:
# do backend em compose.prod.yml (--env-file não repassa automaticamente).
GOOGLE_ROUTES_API_KEY=

# OSRM self-hosted na A1 (issue #4, roteirização). OPCIONAL: vazio/indisponível
# cai em Google/Haversine (fail-open). Default do compose.prod.yml já aponta para
# http://osrm-norte:5000 quando a env está vazia.
#   OSRM_BASE_URL=http://osrm-norte:5000

