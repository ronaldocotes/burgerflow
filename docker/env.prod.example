# MenuFlow production env TEMPLATE. Copy to `.env.prod` ON THE A1 HOST and fill
# in real values with `openssl`. NEVER commit the real .env.prod (it is gitignored;
# only this *.example is tracked).
#
# Generate strong secrets on the host:
#   MF_JWT_SECRET:        openssl rand -base64 48
#   MF_DB_PASSWORD:       openssl rand -base64 24
#   SPRING_REDIS_PASSWORD openssl rand -base64 24

# Public site address served by Caddy (TLS auto). For zero-DNS testing use sslip.io
# with the A1 public IP (dashes), e.g. menuflow.163-176-212-54.sslip.io
SITE_ADDRESS=menuflow.CHANGE-ME.sslip.io

# Postgres (control DB + db-per-tenant). The role must be able to CREATE DATABASE
# (tenants are provisioned on first access).
MF_DB_USER=menuflow
MF_DB_PASSWORD=CHANGE-ME
MF_DB_CONTROL=menuflow_control

# Redis (rate-limit shared counter / cache).
SPRING_REDIS_PASSWORD=CHANGE-ME

# JWT signing secret (HS256, >= 32 bytes). NO dev fallback in prod: if this is
# empty the backend FAILS TO START on purpose (anti token-forgery).
MF_JWT_SECRET=CHANGE-ME
