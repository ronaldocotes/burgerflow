# MenuFlow — Caddy reverse proxy (standalone reference, Oracle A1).
# ONLY Caddy publishes 80/443; everything else stays on the internal Docker
# network. TLS is automatic (Let's Encrypt) for a real domain, or use the
# sslip.io trick for zero-DNS testing: <anything>.<IP-with-dashes>.sslip.io
#
# Set the site address via the {$SITE_ADDRESS} env var, e.g.
#   SITE_ADDRESS=menuflow.duckdns.org
#
# IMPORTANT: this A1 host already runs SISATER/Alicia/Posthumus behind their own
# Caddy on 80/443. Do NOT blindly bind 80/443 again — coordinate with o Capataz:
# either add this site to the EXISTING Caddyfile, or run on a distinct host/port.
# This file is the standalone reference; the Capataz decides how it lands.

{$SITE_ADDRESS} {
	encode gzip zstd

	# WebSocket (KDS/Delivery live updates). The STOMP handshake URL is
	# /api/v1/ws (native) and /api/v1/ws-sockjs/* (SockJS fallback): the endpoint
	# is registered as "/ws" but lives UNDER server.servlet.context-path=/api/v1.
	# Caddy's reverse_proxy transparently upgrades Connection/Upgrade headers, so
	# the /api/v1/* proxy below already covers the WebSocket — no extra matcher.

	# Public smoke needs health only; never expose the rest of actuator.
	reverse_proxy /api/v1/actuator/health backend:8080
	respond /api/v1/actuator/* 404

	# REST API (Spring Boot context-path is /api/v1).
	reverse_proxy /api/v1/* backend:8080

	# Frontend (Next.js) gets everything else.
	reverse_proxy frontend:3000

	header {
		# Basic hardening headers (Caddy already sets sane TLS).
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		-Server
	}
}
