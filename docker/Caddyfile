# BurgerFlow — Caddy reverse proxy (production, Oracle A1 molde SISATER).
# ONLY Caddy publishes 80/443; everything else stays on the internal Docker
# network. TLS is automatic (Let's Encrypt) for a real domain, or use the
# sslip.io trick for zero-DNS testing: <anything>.<IP-with-dashes>.sslip.io
#
# Set the site address via the {$SITE_ADDRESS} env var in .env.prod, e.g.
#   SITE_ADDRESS=burgerflow.163-176-212-54.sslip.io
#
# IMPORTANT: this A1 host already runs SISATER/Alicia/Posthumus behind their own
# Caddy on 80/443. Do NOT blindly bind 80/443 again — coordinate with o Capataz:
# either add this site to the EXISTING Caddyfile, or run on a distinct host/port.
# This file is the standalone reference; the Capataz decides how it lands.

{$SITE_ADDRESS} {
	encode gzip zstd

	# WebSocket (KDS/Delivery live updates). The STOMP endpoint is /ws (root —
	# NOT under /api/v1, a Spring Boot context-path quirk). Caddy's reverse_proxy
	# transparently upgrades Connection/Upgrade headers, so a single matcher works.
	@ws path /ws /ws/* /ws-sockjs/*
	reverse_proxy @ws backend:8080

	# Defense in depth: never expose actuator to the internet (before the API rule).
	respond /api/v1/actuator/* 404

	# REST API (Spring Boot context-path is /api/v1).
	reverse_proxy /api/v1/* backend:8080

	# Frontend (Next.js) gets everything else. The frontend service is commented
	# out in docker-compose.prod.yml until the web app is ready; while it is not
	# deployed, this returns a simple placeholder instead of proxying a dead host.
	# When the frontend ships: replace the `respond` line with
	#   reverse_proxy frontend:3000
	respond / "BurgerFlow API is up. Web app coming soon." 200
	respond "BurgerFlow API is up. Web app coming soon." 200

	header {
		# Basic hardening headers (Caddy already sets sane TLS).
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		-Server
	}
}
